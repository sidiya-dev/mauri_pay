# Flip PRODUCTION to wire/rewire the backend — no code changes needed.
#   PRODUCTION=true   -> API_URL_PROD (deployed backend)
#   PRODUCTION=false  -> API_URL_DEV  (local backend)
PRODUCTION=true

# Deployed MauriPay backend (behind the shared proxy at the /mauripay prefix).
API_URL_PROD=https://51-170-128-214.sslip.io/mauripay

# Local development backend:
# - Android emulator: http://10.0.2.2:8090
# - iOS simulator / desktop / web: http://localhost:8090
# - Physical device: your machine's LAN IP, e.g. http://192.168.1.20:8090
API_URL_DEV=http://10.0.2.2:8090
